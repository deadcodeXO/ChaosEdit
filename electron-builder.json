{
  "appId": "net.functionabuse.chaosedit",
  "productName": "ChaosEdit",
  "asar": true,
  "asarUnpack": [
    "node_modules/monaco-editor/min/vs/**"
  ],
  "files": [
    "standalone-editor/**/*",
    "package.json",
    "node_modules/**/*",
    "!**/*.map",
    "!dist/**",
    "!release/**",
    "!release-fresh/**",
    "!.astro/**",
    "!electron/**",
    "!src/**",
    "!public/**",
    "!docs/**",
    "!scripts/**",
    "!.git/**",
    "!**/goods.png",
    "!**/uglygraybox.png",
    "!**/neweditor.png",
    "!**/boxes.png"
  ],
  "extraMetadata": {
    "name": "chaosedit",
    "main": "standalone-editor/main.js"
  },
  "directories": {
    "output": "release-chaos"
  },
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ]
  }
}
