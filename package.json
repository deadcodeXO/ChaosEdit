{
  "name": "chaosedit",
  "version": "1.0.0",
  "description": "ChaosEdit standalone local-first editor",
  "author": "deadcodeXO",
  "repository": {
    "type": "git",
    "url": "https://github.com/deadcodeXO/ChaosEdit.git"
  },
  "private": false,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "editor:app": "electron .",
    "editor:app:portable": "electron-builder --win portable --config electron-builder.standalone.json",
    "editor:app:installer": "node scripts/build-installer.mjs",
    "editor:app:installer:repo-output": "node scripts/build-installer.mjs --repo-output",
    "start": "electron ."
  },
  "dependencies": {
    "monaco-editor": "^0.53.0"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1"
  }
}
